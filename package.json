{
  "name": "deepseek-excel-assistant",
  "version": "1.0.0",
  "description": "Excel Task Pane Add-in integrating DeepSeek AI for data analysis, formula generation, and content optimization.",
  "main": "src/taskpane/taskpane.ts",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "start:desktop": "office-addin-debugging start manifest.xml desktop",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --pretty"
  },
  "keywords": [
    "office-addin",
    "excel",
    "deepseek",
    "ai",
    "taskpane"
  ],
  "author": "DeepSeek Excel Assistant Team",
  "license": "MIT",
  "dependencies": {
    "@microsoft/office-js": "^1.1.110",
    "core-js": "^3.36.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.2",
    "regenerator-runtime": "^0.14.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/core-js": "^2.5.5",
    "@types/marked": "^6.0.0",
    "@types/node": "^26.1.0",
    "@types/office-js": "^1.0.256",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^29.1.1",
    "office-addin-cli": "^2.0.9",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-dev-settings": "^3.1.1",
    "office-addin-manifest": "^2.1.5",
    "office-addin-prettier-config": "^2.0.4",
    "os-browserify": "^0.3.0",
    "playwright": "^1.61.1",
    "process": "^0.11.10",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
