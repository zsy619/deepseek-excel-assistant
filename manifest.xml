                </Control>
                <Control xsi:type="Button" id="InferColumnTypesButton">
                  <Label resid="InferColumnTypesButton.Label" />
                  <Supertip>
                    <Title resid="InferColumnTypesButton.Label" />
                    <Description resid="InferColumnTypesButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnColtypes.16x16" />
                    <bt:Image size="32" resid="BtnColtypes.32x32" />
                    <bt:Image size="80" resid="BtnColtypes.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>inferColumnTypes</FunctionName>
