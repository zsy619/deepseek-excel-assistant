                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>correlationMatrix</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="DetectOutliersButton">
                  <Label resid="DetectOutliersButton.Label" />
                  <Supertip>
                    <Title resid="DetectOutliersButton.Label" />
                    <Description resid="DetectOutliersButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnOutlier.16x16" />
                    <bt:Image size="32" resid="BtnOutlier.32x32" />
                    <bt:Image size="80" resid="BtnOutlier.80x80" />
