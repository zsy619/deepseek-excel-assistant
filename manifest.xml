<!--
  DeepSeek Excel Assistant — Manifest v1.0.0.0

  IMPORTANT: When modifying this file, keep the following three fields
  EXACTLY unchanged once the add-in is sideloaded via `npm start`:
    - <Id>                 AID = e504fb41-a4b4-4f93-8b3a-d44f23a4f0aa
    - <Version>1.0.0.0</Version>
    - SourceLocation + FunctionFile URLs at https://localhost:3000/

  Changing any of those breaks the Office LTSC 2024 Mac WEF scanner
  sideload path, requiring the full clean-restart procedure
  (delete symlink, drop catalog row, drop tmp xlsx, kill webpack).
-->
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
          xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
          xsi:type="TaskPaneApp">
  <Id>e504fb41-a4b4-4f93-8b3a-d44f23a4f0aa</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>DeepSeek</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="DeepSeek Excel 助手" />
  <Description DefaultValue="DeepSeek AI 驱动的 Excel 助手：公式生成、诊断修复、数据脱敏与可视化" />
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://www.contoso.com/help" />
  <AppDomains>
    <AppDomain>https://localhost:3000</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <!--
            Ribbon layout: 1 custom Tab + 4 Groups + 8 buttons (B 场景: 数据分析师).

            Every Control has its OWN <bt:Image> resource (3 sizes: 16/32/80).
            Office's ribbon falls back to a Logo placeholder if buttons share
            the same image or the image file fails to load, so each button
            gets a dedicated resource ID even though they all share the
            /assets/ribbon-*.png on disk.
          -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="TabDeepSeek">
              <Label resid="CustomTab.Label" />
              <Icon>
                <bt:Image size="16" resid="Icon.16x16" />
                <bt:Image size="32" resid="Icon.32x32" />
                <bt:Image size="80" resid="Icon.80x80" />
              </Icon>

              <!-- ============ Group 1: AI 助手 (主入口) ============ -->
              <Group id="GroupAIAssistant">
                <Label resid="GroupAIAssistant.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="ShowTaskpaneButton">
                  <Label resid="ShowTaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="ShowTaskpaneButton.Label" />
                    <Description resid="ShowTaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnShowTaskpane.16x16" />
                    <bt:Image size="32" resid="BtnShowTaskpane.32x32" />
                    <bt:Image size="80" resid="BtnShowTaskpane.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>OfficeAutoShowTaskpaneId</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
                <Control xsi:type="Button" id="AnalyzeSelectionButton">
                  <Label resid="AnalyzeSelectionButton.Label" />
                  <Supertip>
                    <Title resid="AnalyzeSelectionButton.Label" />
                    <Description resid="AnalyzeSelectionButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnAnalyze.16x16" />
                    <bt:Image size="32" resid="BtnAnalyze.32x32" />
                    <bt:Image size="80" resid="BtnAnalyze.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>analyzeSelection</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- ============ Group 2: 公式与数据 (两步) ============ -->
              <Group id="GroupFormulaData">
                <Label resid="GroupFormulaData.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="GenerateFormulaButton">
                  <Label resid="GenerateFormulaButton.Label" />
                  <Supertip>
                    <Title resid="GenerateFormulaButton.Label" />
                    <Description resid="GenerateFormulaButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnFormula.16x16" />
                    <bt:Image size="32" resid="BtnFormula.32x32" />
                    <bt:Image size="80" resid="BtnFormula.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>generateFormula</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="DiagnoseFormulasButton">
                  <Label resid="DiagnoseFormulasButton.Label" />
                  <Supertip>
                    <Title resid="DiagnoseFormulasButton.Label" />
                    <Description resid="DiagnoseFormulasButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnDiagnose.16x16" />
                    <bt:Image size="32" resid="BtnDiagnose.32x32" />
                    <bt:Image size="80" resid="BtnDiagnose.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>diagnoseFormulas</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="CleanDataButton">
                  <Label resid="CleanDataButton.Label" />
                  <Supertip>
                    <Title resid="CleanDataButton.Label" />
                    <Description resid="CleanDataButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnClean.16x16" />
                    <bt:Image size="32" resid="BtnClean.32x32" />
                    <bt:Image size="80" resid="BtnClean.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>cleanData</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- ============ Group 3: 可视化与代码 ============ -->
              <Group id="GroupVizAndCode">
                <Label resid="GroupVizAndCode.Label" />
