                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>detectOutliers</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="CreatePivotButton">
                  <Label resid="CreatePivotButton.Label" />
                  <Supertip>
                    <Title resid="CreatePivotButton.Label" />
                    <Description resid="CreatePivotButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnPivot.16x16" />
                    <bt:Image size="32" resid="BtnPivot.32x32" />
                    <bt:Image size="80" resid="BtnPivot.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>createPivot</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- ============ Group 6: 报告与数据 (两步) ============ -->
              <Group id="GroupReportData">
                <Label resid="GroupReportData.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="QuickReportButton">
                  <Label resid="QuickReportButton.Label" />
                  <Supertip>
                    <Title resid="QuickReportButton.Label" />
                    <Description resid="QuickReportButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnReport.16x16" />
                    <bt:Image size="32" resid="BtnReport.32x32" />
                    <bt:Image size="80" resid="BtnReport.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>quickReport</FunctionName>
