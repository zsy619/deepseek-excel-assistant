                    <Title resid="TranslateToCodeButton.Label" />
                    <Description resid="TranslateToCodeButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnVba.16x16" />
                    <bt:Image size="32" resid="BtnVba.32x32" />
                    <bt:Image size="80" resid="BtnVba.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>translateToCode</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- ============ Group 4: 数据保护 (两步) ============ -->
              <Group id="GroupDataProtection">
                <Label resid="GroupDataProtection.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="MaskPIIButton">
                  <Label resid="MaskPIIButton.Label" />
                  <Supertip>
                    <Title resid="MaskPIIButton.Label" />
                    <Description resid="MaskPIIButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnPii.16x16" />
                    <bt:Image size="32" resid="BtnPii.32x32" />
                    <bt:Image size="80" resid="BtnPii.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>maskPII</FunctionName>
                  </Action>
                </Control>
              </Group>

              <!-- ============ Group 5: AI 分析 (两步) ============ -->
              <Group id="GroupAIAnalysis">
                <Label resid="GroupAIAnalysis.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
