                </Control>
              </Group>

              <!-- ============ Group 5: 帮助与文档 ============ -->
              <Group id="GroupHelp">
                <Label resid="GroupHelp.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="OpenHelpButton">
                  <Label resid="OpenHelpButton.Label" />
                  <Supertip>
                    <Title resid="OpenHelpButton.Label" />
                    <Description resid="OpenHelpButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="BtnHelp.16x16" />
                    <bt:Image size="32" resid="BtnHelp.32x32" />
                    <bt:Image size="80" resid="BtnHelp.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openHelp</FunctionName>
                  </Action>
                </Control>
              </Group>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
