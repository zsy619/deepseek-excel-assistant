# ============================================================
.env
.env.local
.env.*.local
.env.development
.env.production
# DeepSeek / 其他大模型 API Key 可能落盘的备份
secrets/
*.secret
*.key.json

# ============================================================
#  临时 / 缓存
# ============================================================
.tmp/
.temp/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

