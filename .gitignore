# ============================================================
#  Dependencies
# ============================================================
node_modules/

# ============================================================
#  Build output (Webpack / TypeScript)
# ============================================================
dist/
build/
out/
*.tsbuildinfo
*.map
# Webpack 生产构建可能生成的 sourcemap
*.js.map

# ============================================================
#  Office Add-in 本地调试与开发相关
# ============================================================
# office-addin-debugging / dev-settings 生成的本地配置
*.local.json
# office-addin-dev-certs 生成的本地 HTTPS 证书
*.crt
*.key
*.pem
# 用户本地清单副本（开发期经常出现的临时文件）
manifest.xml.bak-*
manifest*.local.xml

# ============================================================
#  测试与覆盖率产物（Vitest / Playwright）
# ============================================================
coverage/
.nyc_output/
# Playwright 测试产物
test-results/
playwright-report/
playwright/.cache/
blob-report/

# ============================================================
#  IDE / 编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.vs/
*.code-workspace

# ============================================================
#  OS
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ============================================================
#  Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ============================================================
